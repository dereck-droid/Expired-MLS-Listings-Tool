{
  "name": "EquityPro — Monthly Billing Reset",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 0 1 * *"
            }
          ]
        }
      },
      "id": "monthly_trigger",
      "name": "1st of Every Month",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "operation": "create",
        "tableId": "billing_tracker",
        "fieldsUi": {
          "fieldValues": [
            { "fieldName": "month", "fieldValue": "={{ new Date().toISOString().substring(0,7) }}" },
            { "fieldName": "skip_trace_cap", "fieldValue": "200" },
            { "fieldName": "skip_traces_used", "fieldValue": "0" },
            { "fieldName": "total_listings_detected", "fieldValue": "0" }
          ]
        },
        "options": {}
      },
      "id": "create_billing_row",
      "name": "Create New Billing Row",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [220, 0],
      "credentials": { "supabaseApi": { "id": "CONFIGURE_IN_N8N", "name": "Supabase ALS Ops" } },
      "notes": "Creates a new billing_tracker row for the current month with counters reset to 0."
    }
  ],
  "connections": {
    "1st of Every Month": {
      "main": [[{ "node": "Create New Billing Row", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
